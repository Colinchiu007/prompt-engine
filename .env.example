# Prompt Engine 环境变量配置
# 复制此文件为 .env 并填入你的实际值

# LLM 供应商 (xfyun | openai_compat)
LLM_PROVIDER=xfyun

# 讯飞星火配置
XFYUN_API_KEY=your_xfyun_api_key_here
XFYUN_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com
XFYUN_MODEL=astron-code-latest

# OpenAI 兼容配置 (OpenRouter / DeepSeek 等)
OPENAI_COMPAT_API_KEY=your_openai_compat_api_key_here
OPENAI_COMPAT_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPAT_MODEL=anthropic/claude-sonnet-4-20250514
OPENAI_COMPAT_TIMEOUT=60
